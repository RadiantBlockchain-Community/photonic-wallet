# Photonic Wallet VPS Deployment Configuration
#
# Copy this file to .env and adjust values for your deployment.

# Port the wallet web UI is served on (behind reverse proxy)
WALLET_PORT=3000

# ElectrumX server WebSocket URL
# Replace with your own ElectrumX instance for production
# ELECTRUMX_URL=wss://electrumx.yourdomain.com:50004

# Domain for Caddy auto-HTTPS (edit docker/Caddyfile too)
# DOMAIN=wallet.yourdomain.com
